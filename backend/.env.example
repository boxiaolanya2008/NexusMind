# NexusMind Backend Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/nexusmind.db

# JWT Secret
JWT_SECRET=nexusmind-secret-key-change-in-production

# GLM-5 API Configuration
MODEL=glm-5
API=https://open.bigmodel.cn/api/coding/paas/v4
KEY=
TEMPERATURE=0.7

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_TOKENS=10000000

# Knowledge Base
KNOWLEDGE_BASE_PATH=../knowledge_base

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs
